@page
@using Ultimate_HeroEngine.Core.Objects
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}

<div class="text-center">
    <h1 class="display-4">Ultimate Hero Engine: RazorQuest</h1>
    <div>
        <br/><br/><br/><br/><br/>
        <h2>Registered Heroes: @DefaultEntities.Heroes.Count</h2>
        <table>
            <thead>
            <tr>
                <th>Class</th>
                <th>Name</th>
                <th>Base HP</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var hero in DefaultEntities.Heroes)
            {
                <tr>
                    <td>@hero.GetType().Name</td>
                    <td>@hero.Name</td>
                    <td>@hero.MaxHp</td>
                </tr>    
            }
            </tbody>
        </table>
    </div>
</div>