@page
@model FilesModel
@{
    ViewData["Title"] = "Data storage";
}
    <div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Combat Statistics</h1>
        <a asp-page-handler="Download" class="btn btn-success">Download CSV</a>
    </div>

    @if (Model.LastMatches.Count == 0)
    {
        <div class="alert alert-info">No data registered yet.</div>
    }
    else
    {
        <table class="table table-dark table-striped">
            <thead>
            <tr>
                <th>Date</th>
                <th>Result</th>
                <th>Rounds</th>
                <th>Total Damage</th>
                <th>MVP</th>
            </tr>
            </thead>
            <tbody>
            @foreach (var match in Model.LastMatches)
            {
                <tr>
                    <td>@match.Date.ToString("dd/MM HH:mm")</td>
                    <td>
                        <span class="badge @(match.Result == "Victory" ? "bg-success" : "bg-danger")">
                            @match.Result
                        </span>
                    </td>
                    <td>@match.TotalRounds</td>
                    <td>@match.TotalDamage.ToString("N0")</td>
                    <td>@match.EffectiveHero</td>
                </tr>
            }
            </tbody>
        </table>
    }
    <div class="container mt-4">

    <hr class="my-5" style="border-color: #555;" />

    <h2>Configure Game Engine</h2>
    <p class="text-muted">Modify in-game values for the next battle</p>

    <form method="post" asp-page-handler="UpdateConfig">
        
        <div class="row">
            <div class="col-md-6 mb-3">
                <div class="card bg-dark border-secondary">
                    <div class="card-header border-secondary">Base stats</div>
                    <div class="card-body">
                        
                        <div class="mb-3">
                            <label class="form-label" style="color: white">Attack power (all heroes):</label>
                            <input asp-for="CurrentConfig.KeyValues.DefPower" class="form-control bg-secondary text-white border-0" type="number" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label" style="color: white">Level range of enemies (hero levels + [inserted range])</label>
                            <input asp-for="CurrentConfig.KeyValues.RandomLevelRange" class="form-control bg-secondary text-white border-0" type="number" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label" style="color: white">Enemy team size</label>
                            <input asp-for="CurrentConfig.KeyValues.DefTeamSize" class="form-control bg-secondary text-white border-0" type="number" />
                        </div>
                        
                        <div class="mb-3">
                            <label class="form-label" style="color: white">Number of abilities</label>
                            <input asp-for="CurrentConfig.KeyValues.MaxAbilityNum" class="form-control bg-secondary text-white border-0" type="number" />
                        </div>
                        
                    </div>
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-warning mt-3">Save configuration</button>
    </form>
</div>
</div>